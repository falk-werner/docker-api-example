{
    "build": {
        "dockerfile": "Dockerfile",
        "context": ".."
    },
    "remoteUser": "user",
    "mounts": [{
        "source": "${localEnv:HOME}/.ssh",
        "target": "/home/user/.ssh",
        "type": "bind"
    }, {
        "source": "${localEnv:HOME}/.gnupg",
        "target": "/home/user/.gnupg",
        "type": "bind"
    }],
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-vscode.cpptools",
                "ms-vscode.cpptools-extension-pack"
            ],
            "settings": {
                "terminal.integrated.defaultProfile.linux": "bash"
            }
        }
    }
}